MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=podologia_app
MYSQL_USER=podologia
MYSQL_PASSWORD=change-me-db

JWT_SECRET=change-me-jwt

ADMIN_EMAIL=admin@tuapp.com
ADMIN_PASSWORD=change-me-admin

NODE_ENV=production
PORT=4000

PLATFORM_APEX_DOMAIN=tuapp.com
PLATFORM_DOMAIN_CNAME_TARGET=domains.tuapp.com
PLATFORM_DOMAIN_A_RECORDS=203.0.113.10
PLATFORM_DOMAIN_SSL_STRATEGY=CADDY_ON_DEMAND_TLS
CADDY_ON_DEMAND_ASK_SECRET=change-me-caddy-secret
ACME_EMAIL=tu-email@tuapp.com

APP_BASE_URL=https://tuapp.com
API_BASE_URL=https://tuapp.com
FRONTEND_URL=https://tuapp.com
MERCADO_PAGO_OAUTH_CLIENT_ID=APP_USR-XXXXXXXXXXXXXXXXXXXX
MERCADO_PAGO_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_OAUTH_REDIRECT_URI=https://tuapp.com/api/payments/mercadopago/oauth/callback
MERCADO_PAGO_PLATFORM_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

EMAIL_PROVIDER=resend
RESEND_API_KEY=
