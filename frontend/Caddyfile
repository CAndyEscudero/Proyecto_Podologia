{
	email {$ACME_EMAIL}

	on_demand_tls {
		ask {$CADDY_ASK_URL}
	}
}

https:// {
	tls {
		on_demand
	}

	encode zstd gzip

	handle /health {
		reverse_proxy backend:4000
	}

	handle /api {
		reverse_proxy backend:4000
	}

	handle /api/* {
		reverse_proxy backend:4000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
