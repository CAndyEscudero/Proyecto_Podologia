PORT=4000
NODE_ENV=development
DATABASE_URL="mysql://<db-user>:<db-password>@localhost:3307/podologia_app"
JWT_SECRET=<set-a-local-jwt-secret>
JWT_EXPIRES_IN=7d
CADDY_ON_DEMAND_ASK_SECRET=<set-a-secret-for-caddy-on-demand-tls>
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
PLATFORM_APEX_DOMAIN=localhost
PLATFORM_DOMAIN_CNAME_TARGET=localhost
PLATFORM_DOMAIN_A_RECORDS=127.0.0.1
PLATFORM_DOMAIN_SSL_STRATEGY=INFRASTRUCTURE_MANAGED
ADMIN_EMAIL=<set-a-local-admin-email>
ADMIN_PASSWORD=<set-a-local-admin-password>
MERCADO_PAGO_OAUTH_CLIENT_ID=<set-your-platform-client-id>
MERCADO_PAGO_OAUTH_CLIENT_SECRET=<set-your-platform-client-secret>
MERCADO_PAGO_OAUTH_REDIRECT_URI=http://localhost:4000/api/payments/mercadopago/oauth/callback
MERCADO_PAGO_PLATFORM_WEBHOOK_SECRET=<set-your-platform-webhook-secret>
MP_ACCESS_TOKEN=<set-a-local-mercado-pago-access-token>
MP_PUBLIC_KEY=<set-a-local-mercado-pago-public-key>
MP_WEBHOOK_SECRET=<set-a-local-mercado-pago-webhook-secret>
EMAIL_PROVIDER=resend
RESEND_API_KEY=<optional-resend-api-key>
PLATFORM_EMAIL_FROM=onboarding@resend.dev
