LOG_LEVEL=info
FRONTEND_ERROR_LOGGING_ENABLED=true
VITE_FRONTEND_ERROR_LOGGING_ENABLED=true

JOBS_ENABLED=true
PENDING_RESERVATIONS_JOB_INTERVAL_MS=60000
APPOINTMENT_REMINDER_JOB_INTERVAL_MS=300000
APPOINTMENT_REMINDER_LEAD_MINUTES=1440
APPOINTMENT_REMINDER_RETRY_DELAY_MINUTES=30
APPOINTMENT_REMINDER_MAX_ATTEMPTS=3

LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
